---
const today = new Date();
---

<footer>
	<div class="inner">
		<span class="copy">&copy; {today.getFullYear()} HexUp</span>
	</div>
</footer>
<style>
	footer {
		margin-top: 4rem;
		padding: 2.5rem 1rem;
		border-top: 1px solid rgba(var(--gray-light), 1);
	}
	.inner {
		max-width: 720px;
		margin: 0 auto;
		text-align: center;
	}
	.copy {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: rgb(var(--gray));
		letter-spacing: 0.02em;
	}
</style>
