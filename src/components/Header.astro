---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname;
const isBlogActive = pathname === '/blog' || pathname.startsWith('/blog/');
---

<header>
	<div class="inner">
		<a class="brand" href="/" aria-label={`${SITE_TITLE} home`}>
			<span class="brand-mark">{SITE_TITLE}</span>
		</a>
		<nav class="nav" aria-label="Primary">
			<a href="/blog" class:list={['nav-link', { active: isBlogActive }]}>Blog</a>
		</nav>
	</div>
</header>
<style>
	header {
		border-bottom: 1px solid rgba(var(--gray-light), 1);
		background: transparent;
	}
	.inner {
		max-width: 720px;
		margin: 0 auto;
		padding: 1.25rem 1rem;
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1.5rem;
	}
	.brand {
		display: inline-flex;
		align-items: baseline;
		text-decoration: none;
		color: rgb(var(--black));
		transition: opacity 0.15s ease;
	}
	.brand:hover {
		opacity: 0.7;
	}
	.brand-mark {
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: 1.05rem;
		letter-spacing: -0.01em;
		line-height: 1;
	}
	.nav {
		display: flex;
		gap: 1.5rem;
	}
	.nav-link {
		position: relative;
		font-family: var(--font-mono);
		font-size: 0.9rem;
		font-weight: 500;
		color: rgb(var(--gray));
		text-decoration: none;
		padding: 0.15em 0;
		line-height: 1;
		transition: color 0.15s ease;
	}
	.nav-link::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: -2px;
		height: 1px;
		background: currentColor;
		transform: scaleX(0);
		transform-origin: left center;
		transition: transform 0.2s ease;
	}
	.nav-link:hover {
		color: rgb(var(--black));
	}
	.nav-link:hover::after,
	.nav-link.active::after {
		transform: scaleX(1);
	}
	.nav-link.active {
		color: rgb(var(--black));
	}
	@media (max-width: 720px) {
		.inner {
			padding: 1rem 1rem;
		}
		.brand-mark {
			font-size: 1rem;
		}
		.nav-link {
			font-size: 0.875rem;
		}
	}
</style>
